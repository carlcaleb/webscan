# ================== ANONYMITY & PROXY MANAGEMENT ==================
class AnonymityManager:
    """Handles Tor and proxy rotation for anonymity"""
    @staticmethod
    def verify_tor_connection():
        try:
            proxies = {'http': config.PROXY, 'https': config.PROXY}
            response = requests.get('https://check.torproject.org/api/ip', 
                                  proxies=proxies, 
                                  timeout=10)
            return response.json().get('IsTor', False)
        except Exception as e:
            logging.error(f"Tor verification failed: {e}")
            return False

    @staticmethod
    def renew_tor_identity():
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.connect(("127.0.0.1", config.TOR_CONTROL_PORT))
                s.send(f"AUTHENTICATE \"{config.TOR_CONTROL_PASSWORD}\"\r\n".encode())
                response = s.recv(1024)
                if b'250' not in response:
                    raise Exception("Tor authentication failed")
                s.send(b"SIGNAL NEWNYM\r\n")
                response = s.recv(1024)
                if b'250' not in response:
                    raise Exception("Tor IP change failed")
                logging.info("Successfully rotated Tor IP")
                return True
        except Exception as e:
            logging.error(f"Tor IP rotation failed: {e}")
            return False

class ProxyManager:
    """Manages residential proxy rotation"""
    @staticmethod
    def get_current_proxy():
        if not config.PROXY_ROTATION:
            return config.PROXY
            
        if random.random() < 0.7 and config.RESIDENTIAL_PROXIES:
            return random.choice(config.RESIDENTIAL_PROXIES)
        return config.PROXY

    @staticmethod
    def get_proxy_dict():
        proxy = ProxyManager.get_current_proxy()
        return {'http': proxy, 'https': proxy, 'no_proxy': 'localhost,127.0.0.1'}

    @staticmethod
    def rotate_proxy():
        """Rotate between different proxy options"""
        if config.RESIDENTIAL_PROXIES:
            config.PROXY = random.choice(config.RESIDENTIAL_PROXIES)
        else:
            config.PROXY = "socks5://127.0.0.1:9150"
        logging.info(f"Rotated proxy to: {config.PROXY}")

# ================== CAPTCHA BYPASS ==================
class CaptchaSolver:
    """Handles CAPTCHA solving using external services"""
    @staticmethod
    def solve_captcha(driver, site_key=None, url=None):
        if not config.CAPTCHA_API_KEY:
            return False
            
        try:
            if "cloudflare" in driver.page_source.lower():
                return CaptchaSolver._solve_cloudflare(driver)
            elif site_key:
                return CaptchaSolver._solve_recaptcha(driver, site_key, url)
        except Exception as e:
            logging.error(f"CAPTCHA solve failed: {e}")
        return False

    @staticmethod
    def _solve_cloudflare(driver):
        try:
            WebDriverWait(driver, 15).until(
                EC.frame_to_be_available_and_switch_to_it((By.CSS_SELECTOR, "iframe[title*='Challenge']"))
            )
            checkbox = WebDriverWait(driver, 15).until(
                EC.element_to_be_clickable((By.CSS_SELECTOR, ".recaptcha-checkbox"))
            )
            checkbox.click()
            driver.switch_to.default_content()
            return True
        except:
            return False

    @staticmethod
    def _solve_recaptcha(driver, site_key, page_url):
        api_url = "http://2captcha.com/in.php"
        params = {
            'key': config.CAPTCHA_API_KEY,
            'method': 'userrecaptcha',
            'googlekey': site_key,
            'pageurl': page_url,
            'json': 1
        }
        
        response = requests.post(api_url, params, timeout=30).json()
        if response.get('status') != 1:
            return False
            
        captcha_id = response['request']
        solution = None
        
        for _ in range(config.CAPTCHA_MAX_RETRIES):
            time.sleep(config.CAPTCHA_TIMEOUT // config.CAPTCHA_MAX_RETRIES)
            result = requests.get(
                f"http://2captcha.com/res.php?key={config.CAPTCHA_API_KEY}&action=get&id={captcha_id}&json=1"
            ).json()
            
            if result.get('status') == 1:
                solution = result['request']
                break
                
        if not solution:
            return False
            
        driver.execute_script(
            f'document.getElementById("g-recaptcha-response").innerHTML="{solution}";'
        )
        driver.execute_script(
            '___grecaptcha_cfg.clients[0].L.L.callback()'
        )
        return True

# ================== SECURITY UTILITIES ==================
class SecurityUtils:
    """Security-related utilities for encryption and secure storage"""
    @staticmethod
    def encrypt_data(data: str) -> str:
        """Encrypt sensitive data using AES-256-CBC"""
        try:
            iv = get_random_bytes(16)
            cipher = AES.new(config.ENCRYPTION_KEY, AES.MODE_CBC, iv)
            ct_bytes = cipher.encrypt(pad(data.encode('utf-8'), AES.block_size))
            return base64.b64encode(iv + ct_bytes).decode('utf-8')
        except Exception as e:
            logging.error(f"Encryption failed: {e}")
            return data
            
    @staticmethod
    def decrypt_data(enc_data: str) -> str:
        """Decrypt AES-256-CBC encrypted data"""
        try:
            data = base64.b64decode(enc_data)
            iv = data[:16]
            ct = data[16:]
            cipher = AES.new(config.ENCRYPTION_KEY, AES.MODE_CBC, iv)
            pt = unpad(cipher.decrypt(ct), AES.block_size)
            return pt.decode('utf-8')
        except Exception as e:
            logging.error(f"Decryption failed: {e}")
            return enc_data

# ================== PERFORMANCE OPTIMIZATION ==================
def monitor_resources():
    """Monitor system resources and adjust operations accordingly"""
    try:
        import psutil
    except ImportError:
        logging.warning("psutil not installed. Resource monitoring disabled.")
        return
        
    while True:
        mem = psutil.virtual_memory()
        cpu_percent = psutil.cpu_percent()
        
        logging.info(f"System Resources - CPU: {cpu_percent}%, Memory: {mem.percent}%")
        
        # Adaptive throttling
        if mem.percent > config.MEMORY_THRESHOLD or cpu_percent > 80:
            config.REQUEST_DELAY = (3.0, 8.0)  # Slow down under load
        else:
            config.REQUEST_DELAY = (1.5, 4.0)  # Normal speed
        
        if mem.percent > config.MEMORY_THRESHOLD:
            logging.warning(f"High memory usage ({mem.percent}%). Clearing caches...")
            # Clear more aggressively
            if 'driver' in globals():
                try:
                    globals()['driver'].quit()
                except:
                    pass
            if 'soup' in globals():
                try:
                    globals()['soup'].decompose()
                except:
                    pass
            gc.collect()
        
        # Rotate proxy periodically
        if random.random() < 0.3:  # 30% chance to rotate
            ProxyManager.rotate_proxy()
            if "tor" in config.PROXY.lower():
                AnonymityManager.renew_tor_identity()
        
        time.sleep(30)

