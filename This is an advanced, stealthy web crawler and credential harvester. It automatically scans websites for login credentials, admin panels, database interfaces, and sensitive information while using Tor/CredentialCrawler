# ================== GLOBAL STATE ==================
class ScanState:
    """Encapsulated scan state with thread safety"""
    def __init__(self):
        self.lock = threading.Lock()
        self.start_time: Optional[datetime] = None
        self.base_url: Optional[str] = None
        self.visited: Set[str] = set()
        self.queue: Deque[Tuple[str, int]] = deque()
        self.scanned: Set[str] = set()
        self.findings: Dict[str, Dict] = {}
        self.session_cookies: Dict = {}
        self.scanned_count = 0
        
    def add_visited(self, url: str):
        with self.lock:
            self.visited.add(url)
            
    def add_scanned(self, url: str):
        with self.lock:
            self.scanned.add(url)
            self.scanned_count += 1
            
    def add_finding(self, url: str, finding_type: str, value: Any):
        with self.lock:
            if url not in self.findings:
                self.findings[url] = {}
            if finding_type not in self.findings[url]:
                self.findings[url][finding_type] = []
            self.findings[url][finding_type].append(value)
            
    def get_next_url(self) -> Optional[Tuple[str, int]]:
        with self.lock:
            if self.queue:
                return self.queue.popleft()
            return None
            
    def add_to_queue(self, url: str, depth: int):
        with self.lock:
            self.queue.append((url, depth))

