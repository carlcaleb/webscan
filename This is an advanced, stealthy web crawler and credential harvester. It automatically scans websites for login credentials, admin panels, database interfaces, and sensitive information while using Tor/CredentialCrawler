# ================== UTILITY FUNCTIONS ==================
def ensure_output_dir():
    os.makedirs(config.OUTPUT_DIR, exist_ok=True)

def save_finding(url: str, finding_type: str, value: str, confidence: str = "medium"):
    """Save encrypted findings with retries and error handling"""
    ensure_output_dir()
    
    # Encrypt sensitive findings
    if any(kw in finding_type.lower() for kw in ["password", "key", "secret", "token", "credit", "cvv", "ssn"]):
        value = SecurityUtils.encrypt_data(value)
    
    for attempt in range(config.FILE_ACCESS_RETRIES):
        try:
            file_exists = os.path.isfile(config.OUTPUT_FILE_CSV)
            
            with open(config.OUTPUT_FILE_CSV, 'a', newline='', encoding='utf-8') as f:
                writer = csv.writer(f)
                if not file_exists:
                    writer.writerow(["Timestamp", "URL", "Category", "Type", "Value", "Confidence", "Verified"])
                
                timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                # Split category and type from finding_type
                if ":" in finding_type:
                    category, finding = finding_type.split(":", 1)
                else:
                    category = "General"
                    finding = finding_type
                    
                writer.writerow([timestamp, url, category.strip(), finding.strip(), value, confidence, "False"])
            return
        except (PermissionError, BlockingIOError) as e:
            if attempt < config.FILE_ACCESS_RETRIES - 1:
                logging.warning(f"File access error (attempt {attempt+1}/{config.FILE_ACCESS_RETRIES}): {e}. Retrying...")
                time.sleep(config.FILE_ACCESS_DELAY)
            else:
                logging.error(f"Critical file access error: {e}. Could not save finding.")
        except Exception as e:
            logging.exception(f"Unexpected error saving finding: {e}")

def save_findings_json(findings: Dict):
    """Save all findings to JSON with incremental updates"""
    ensure_output_dir()
    temp_file = config.OUTPUT_FILE_JSON + ".tmp"
    
    try:
        # Save to temporary file first
        with open(temp_file, 'w', encoding='utf-8') as f:
            json.dump(findings, f, indent=2, default=str)
        
        # Atomically replace the old file
        if os.path.exists(config.OUTPUT_FILE_JSON):
            os.remove(config.OUTPUT_FILE_JSON)
        os.rename(temp_file, config.OUTPUT_FILE_JSON)
    except Exception as e:
        logging.exception(f"Error saving JSON findings: {e}")
        try:
            os.remove(temp_file)
        except:
            pass

def print_finding(url: str, finding_type: str, value: str, confidence: str = "medium"):
    """Print and save a finding immediately with error handling"""
    color = Fore.RED if confidence == "high" else Fore.YELLOW
    if confidence == "critical":
        color = Fore.MAGENTA
        
    # Split category and type for display
    if ":" in finding_type:
        category, finding = finding_type.split(":", 1)
        display_text = f"{category.strip()}: {finding.strip()}"
    else:
        display_text = finding_type
        
    print(f"{color}[+] {display_text}: {value} (Confidence: {confidence}){Style.RESET_ALL}")
    save_finding(url, finding_type, value, confidence)

def save_scan_state():
    """Save current scan state to resume later with error handling"""
    if not current_scan_state.base_url:
        return
        
    try:
        compressed_visited = base64.b64encode(
            zlib.compress(
                json.dumps(list(current_scan_state.visited)).encode('utf-8')
            )
        ).decode('utf-8')
    except Exception as e:
        logging.error(f"Error compressing scan state: {e}")
        return
    
    state = {
        "start_time": current_scan_state.start_time.isoformat() if current_scan_state.start_time else None,
        "base_url": current_scan_state.base_url,
        "visited": compressed_visited,
        "queue": list(current_scan_state.queue),
        "scanned": list(current_scan_state.scanned),
        "findings": current_scan_state.findings,
        "session_cookies": list(current_scan_state.session_cookies.items()),
        "scanned_count": current_scan_state.scanned_count
    }
    
    ensure_output_dir()
    for attempt in range(config.FILE_ACCESS_RETRIES):
        try:
            with open(config.SCAN_STATE_FILE, 'w', encoding='utf-8') as f:
                json.dump(state, f, indent=2)
            return
        except (PermissionError, BlockingIOError) as e:
            if attempt < config.FILE_ACCESS_RETRIES - 1:
                logging.warning(f"State save error (attempt {attempt+1}/{config.FILE_ACCESS_RETRIES}): {e}. Retrying...")
                time.sleep(config.FILE_ACCESS_DELAY)
            else:
                logging.error(f"Critical state save error: {e}")
        except Exception as e:
            logging.exception(f"Unexpected state save error: {e}")

