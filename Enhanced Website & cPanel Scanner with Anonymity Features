def save_scan_state():
    """Save current scan state to resume later with error handling"""
    if not current_scan_state.base_url:
        return
        
    try:
        compressed_visited = base64.b64encode(
            zlib.compress(
                json.dumps(list(current_scan_state.visited)).encode('utf-8')
            )
        ).decode('utf-8')
    except Exception as e:
        logging.error(f"Error compressing scan state: {e}")
        return
    
    state = {
        "start_time": current_scan_state.start_time.isoformat() if current_scan_state.start_time else None,
        "base_url": current_scan_state.base_url,
        "visited": compressed_visited,
        "queue": list(current_scan_state.queue),
        "scanned": list(current_scan_state.scanned),
        "findings": current_scan_state.findings,
        "session_cookies": list(current_scan_state.session_cookies.items()),
        "scanned_count": current_scan_state.scanned_count
    }
    
    ensure_output_dir()
    for attempt in range(config.FILE_ACCESS_RETRIES):
        try:
            with open(config.SCAN_STATE_FILE, 'w', encoding='utf-8') as f:
                json.dump(state, f, indent=2)
            return
        except (PermissionError, BlockingIOError) as e:
            if attempt < config.FILE_ACCESS_RETRIES - 1:
                logging.warning(f"State save error (attempt {attempt+1}/{config.FILE_ACCESS_RETRIES}): {e}. Retrying...")
                time.sleep(config.FILE_ACCESS_DELAY)
            else:
                logging.error(f"Critical state save error: {e}")
        except Exception as e:
            logging.exception(f"Unexpected state save error: {e}")

def load_scan_state():
    """Load scan state from file if exists"""
    if not os.path.exists(config.SCAN_STATE_FILE):
        return None
        
    try:
        with open(config.SCAN_STATE_FILE, 'r', encoding='utf-8') as f:
            state = json.load(f)
            
        try:
            decompressed = zlib.decompress(
                base64.b64decode(state["visited"])
            ).decode('utf-8')
            visited = set(json.loads(decompressed))
        except Exception as e:
            logging.error(f"Error decompressing visited URLs: {e}")
            visited = set()
        
        scan_state = ScanState()
        scan_state.start_time = datetime.fromisoformat(state["start_time"]) if state["start_time"] else None
        scan_state.base_url = state["base_url"]
        scan_state.visited = visited
        scan_state.queue = deque(state["queue"])
        scan_state.scanned = set(state["scanned"])
        scan_state.findings = state["findings"]
        scan_state.session_cookies = dict(state["session_cookies"])
        scan_state.scanned_count = state.get("scanned_count", 0)
        
        return scan_state
    except Exception as e:
        logging.exception(f"Error loading scan state: {e}")
        return None

