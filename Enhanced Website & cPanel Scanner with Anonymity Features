# ================== GLOBAL STATE ==================
class ScanState:
    """Encapsulated scan state with thread safety"""
    def __init__(self):
        self.lock = threading.Lock()
        self.start_time: Optional[datetime] = None
        self.base_url: Optional[str] = None
        self.visited: Set[str] = set()
        self.queue: Deque[Tuple[str, int]] = deque()
        self.scanned: Set[str] = set()
        self.findings: Dict[str, Dict] = {}
        self.session_cookies: Dict = {}
        self.scanned_count = 0
        
    def add_visited(self, url: str):
        with self.lock:
            self.visited.add(url)
            
    def add_scanned(self, url: str):
        with self.lock:
            self.scanned.add(url)
            self.scanned_count += 1
            
    def add_finding(self, url: str, finding_type: str, value: Any):
        with self.lock:
            if url not in self.findings:
                self.findings[url] = {}
            if finding_type not in self.findings[url]:
                self.findings[url][finding_type] = []
            self.findings[url][finding_type].append(value)
            
    def get_next_url(self) -> Optional[Tuple[str, int]]:
        with self.lock:
            if self.queue:
                return self.queue.popleft()
            return None
            
    def add_to_queue(self, url: str, depth: int):
        with self.lock:
            self.queue.append((url, depth))

current_scan_state = ScanState()

# ================== SECURITY UTILITIES ==================
class SecurityUtils:
    """Security-related utilities for encryption and secure storage"""
    @staticmethod
    def encrypt_data(data: str) -> str:
        """Encrypt sensitive data using AES-256-CBC"""
        try:
            iv = get_random_bytes(16)
            cipher = AES.new(config.ENCRYPTION_KEY, AES.MODE_CBC, iv)
            ct_bytes = cipher.encrypt(pad(data.encode('utf-8'), AES.block_size))
            return base64.b64encode(iv + ct_bytes).decode('utf-8')
        except Exception as e:
            logging.error(f"Encryption failed: {e}")
            return data
            
    @staticmethod
    def decrypt_data(enc_data: str) -> str:
        """Decrypt AES-256-CBC encrypted data"""
        try:
            data = base64.b64decode(enc_data)
            iv = data[:16]
            ct = data[16:]
            cipher = AES.new(config.ENCRYPTION_KEY, AES.MODE_CBC, iv)
            pt = unpad(cipher.decrypt(ct), AES.block_size)
            return pt.decode('utf-8')
        except Exception as e:
            logging.error(f"Decryption failed: {e}")
            return enc_data

    @staticmethod
    def rotate_proxy():
        """Rotate between different proxy options"""
        if config.RESIDENTIAL_PROXIES:
            config.PROXY = random.choice(config.RESIDENTIAL_PROXIES)
        else:
            config.PROXY = config.TOR_PROXY
        logging.info(f"Rotated proxy to: {config.PROXY}")

# ================== ANONYMITY FEATURES ==================
class AnonymityManager:
    """Manage anonymity features including Tor and proxy rotation"""
    @staticmethod
    def check_tor():
        """Verify Tor connection"""
        try:
            session = requests.session()
            session.proxies = {
                'http': config.TOR_PROXY,
                'https': config.TOR_PROXY
            }
            response = session.get('https://check.torproject.org/api/ip')
            return response.json().get('IsTor', False)
        except:
            return False

    @staticmethod
    def renew_tor_identity():
        """Renew Tor circuit to get new IP"""
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.connect(('127.0.0.1', 9051))  # Tor control port
                s.send(b'AUTHENTICATE ""\r\n')
                response = s.recv(1024)
                if b'250' in response:
                    s.send(b'SIGNAL NEWNYM\r\n')
                    response = s.recv(1024)
                    if b'250' in response:
                        return True
        except:
            pass
        return False

    @staticmethod
    def setup_anonymous_driver():
        """Configure driver with anonymity features"""
        chrome_options = Options()
        
        # Proxy configuration
        if config.PROXY:
            chrome_options.add_argument(f'--proxy-server={config.PROXY}')
        
        # Fingerprint obfuscation
        chrome_options.add_argument("--disable-blink-features=AutomationControlled")
        chrome_options.add_experimental_option("excludeSwitches", ["enable-automation"])
        chrome_options.add_experimental_option('useAutomationExtension', False)
        
        # Random window size
        width = random.randint(1200, 1920)
        height = random.randint(800, 1080)
        chrome_options.add_argument(f"--window-size={width},{height}")
        
        return chrome_options

# ================== PERFORMANCE OPTIMIZATION ==================
def monitor_resources():
    """Monitor system resources and adjust operations accordingly"""
    try:
        import psutil
    except ImportError:
        logging.warning("psutil not installed. Resource monitoring disabled.")
        return
        
    while True:
        mem = psutil.virtual_memory()
        cpu_percent = psutil.cpu_percent()
        
        logging.info(f"System Resources - CPU: {cpu_percent}%, Memory: {mem.percent}%")
        
        # Adaptive throttling
        if mem.percent > config.MEMORY_THRESHOLD or cpu_percent > 80:
            config.REQUEST_DELAY = (3.0, 8.0)  # Slow down under load
        else:
            config.REQUEST_DELAY = (1.5, 4.0)  # Normal speed
        
        if mem.percent > config.MEMORY_THRESHOLD:
            logging.warning(f"High memory usage ({mem.percent}%). Clearing caches...")
            # Clear more aggressively
            if 'driver' in globals():
                try:
                    globals()['driver'].quit()
                except:
                    pass
            if 'soup' in globals():
                try:
                    globals()['soup'].decompose()
                except:
                    pass
            gc.collect()
        
        # Rotate proxy periodically
        if random.random() < 0.3:  # 30% chance to rotate
            SecurityUtils.rotate_proxy()
            if "tor" in config.PROXY.lower():
                AnonymityManager.renew_tor_identity()
        
        time.sleep(30)

