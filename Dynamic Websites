def handle_js_rendering(url):
    try:
        chrome_options = Options()
        chrome_options.add_argument("--headless=new")
        chrome_options.add_argument("--disable-gpu")
        chrome_options.add_argument("--no-sandbox")
        chrome_options.add_argument("--disable-dev-shm-usage")
        chrome_options.add_argument("--disable-blink-features=AutomationControlled")
        chrome_options.add_argument(f"--user-agent={random.choice(USER_AGENTS)}")
        chrome_options.add_argument("--window-size=1920,1080")
        driver = webdriver.Chrome(options=chrome_options)
        driver.execute_script("""
            delete navigator.__proto__.webdriver;
            window.chrome = {runtime: {}};
            Object.defineProperty(navigator, 'languages', {get: () => ['en-US', 'en']});
            Object.defineProperty(navigator, 'plugins', {get: () => [1, 2, 3, 4, 5]});
        """)
        print(f"[*] Rendering {url}...")
        driver.set_page_load_timeout(60)
        driver.get(url)
        WebDriverWait(driver, 20).until(
            EC.presence_of_element_located((By.TAG_NAME, "body"))
        )
        driver.execute_script("window.scrollTo(0, document.body.scrollHeight);")
        time.sleep(random.uniform(5, 10))
        html = driver.page_source
        driver.quit()
        return html
    except Exception as e:
        print(f"[!] JS rendering failed: {str(e)}")
        return ""

def fetch_page(url):
    try:
        headers = {"User-Agent": random.choice(USER_AGENTS)}
        response = requests.get(url, headers=headers, timeout=15)
        if response.status_code == 200:
            return response.text
        else:
            print(f"[!] Failed to fetch {url} - Status code: {response.status_code}")
    except Exception as e:
        print(f"[!] Error fetching {url}: {e}")
    return ""

def crawl_website(start_url, max_depth=MAX_DEPTH, use_js=False):
    queue = [(start_url, 0)]
    while queue:
        url, depth = queue.pop(0)
        if url in VISITED_URLS or depth > max_depth:
            continue
        print(f"[*] Crawling: {url}")
        html = fetch_page(url)
        if not html and use_js:
            html = handle_js_rendering(url)
        if html:
            secrets = scan_content_for_secrets(html, url)
            ALL_RESULTS.extend(secrets)
            links = extract_links(html, start_url)
            for link in links:
                if link not in VISITED_URLS:
                    queue.append((link, depth + 1))
        VISITED_URLS.add(url)
        time.sleep(random.uniform(0.5, 1.5))

def extract_links(html, base_url):
    soup = BeautifulSoup(html, "html.parser")
    links = set()
    for a_tag in soup.find_all("a", href=True):
        full_url = urljoin(base_url, a_tag["href"])
        if is_valid_url(full_url):
            links.add(full_url)
    return links

def is_valid_url(url):
    parsed = urlparse(url)
    domain_info = extract(url)
    return bool(parsed.scheme in ['http', 'https']) and domain_info.domain == TARGET_DOMAIN

