def detect_chain(address):
    address = address.strip()
    if re.match(r"^0x[a-fA-F0-9]{40}$", address): return "ethereum"
    elif re.match(r"^(1|3)[a-km-zA-HJ-NP-Z0-9]{25,34}$", address): return "bitcoin"
    elif re.match(r"^bc1[ac-hj-np-z02-9]{6,86}$", address): return "bitcoin-segwit"
    elif re.match(r"^[1-9A-HJ-NP-Za-km-z]{44}$", address): return "solana"
    else: return "unknown"

def contains_seed_phrase(text):
    words = re.findall(r'\b\w+\b', text.lower())
    matched_words = [w for w in words if w in BIP39_WORDS]
    candidates = []
    i = 0
    while i < len(matched_words):
        j = i
        phrase = []
        while j < len(matched_words) and matched_words[j] in BIP39_WORDS:
            phrase.append(matched_words[j])
            j += 1
        if len(phrase) >= 3:
            candidates.append(' '.join(phrase[:12]))
        i = j + 1 if j == i else j
    return candidates

def scan_content_for_secrets(html, base_url):
    results = []
    for name, pattern in CRYPTO_PATTERNS.items():
        matches = re.findall(pattern, html, re.IGNORECASE | re.DOTALL)
        for match in matches:
            results.append({
                "type": name,
                "match": str(match).strip(),
                "url": base_url
            })
    seed_phrases = contains_seed_phrase(html)
    for phrase in seed_phrases:
        results.append({
            "type": "Seed Phrase Candidate",
            "match": phrase,
            "url": base_url
        })
    return results

