# ASN.1 DER Parser Function
# ========================
def parse_asn1_der(hex_data):
    try:
        stream = Stream(hex_data)
        return ASN1(stream)
    except Exception as e:
        print(f"[!] ASN.1 decoding failed: {e}")
        return None

