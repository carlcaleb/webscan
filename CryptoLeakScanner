def graceful_exit(signal_received, frame):
    print("\n[!] Scan interrupted. Saving final findings...")
    if ALL_RESULTS:
        export_to_desktop_csv(ALL_RESULTS)
    else:
        print("[*] No findings to export.")
    sys.exit(0)

