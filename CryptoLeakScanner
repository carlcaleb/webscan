# ========================
# Chain Detection
# ========================
def detect_chain(address):
    address = address.strip()
    if re.match(r"^0x[a-fA-F0-9]{40}$", address): return "ethereum"
    elif re.match(r"^(1|3)[a-km-zA-HJ-NP-Z0-9]{25,34}$", address): return "bitcoin"
    elif re.match(r"^bc1[ac-hj-np-z02-9]{6,86}$", address): return "bitcoin-segwit"
    elif re.match(r"^[1-9A-HJ-NP-Za-km-z]{44}$", address): return "solana"
    elif re.match(r"^4[0-9AB][1-9A-HJ-NP-Za-km-z]{93,104}$", address): return "monero"
    elif re.match(r"^addr1[0-9a-zA-Z]{54,64}$", address): return "cardano"
    elif re.match(r"^(L|M)[a-km-zA-HJ-NP-Z1-9]{25,34}$", address): return "litecoin"
    elif re.match(r"^D{1}[5-9A-HJ-NP-U][1-9A-HJ-NP-Za-km-z]{32,33}$", address): return "dogecoin"
    return "unknown"

# ========================
# Seed Phrase Detection
# ========================
BIP39_WORDS = {
    "abandon", "ability", "able", "about", "above", "absent", "academy", "accelerate", "account",
    "accuse", "achieve", "acid", "acoustic", "acquire", "across", "action", "actor", "actress", "actual", "adapt"
}

def contains_seed_phrase(html):
    candidates = []
    words = re.findall(r'\b(?:' + '|'.join(BIP39_WORDS) + r')\b', html, re.IGNORECASE)
    i = 0
    while i < len(words):
        phrase = []
        count = 0
        j = i
        while j < len(words) and count < 24:
            word = words[j].lower()
            if word in BIP39_WORDS:
                phrase.append(word)
                count += 1
            else:
                break
            j += 1
        if count >= 12:
            candidates.append(" ".join(phrase))
        i = j + 1 if j == i else j
    return candidates

# ========================
# Scan Content for Secrets
# ========================
def scan_content_for_secrets(html, base_url):
    results = []

    for name, pattern in CRYPTO_PATTERNS.items():
        matches = re.findall(pattern, html, re.IGNORECASE | re.DOTALL)
        for match in matches:
            match = str(match).strip()
            entry_key = (name, match, base_url)
            if entry_key in SEEN_ENTRIES:
                continue
            SEEN_ENTRIES.add(entry_key)

            result = {
                "type": name,
                "match": match,
                "url": base_url,
                "chain": detect_chain(match),
                "valid": False
            }

            if name == "Private Key (Hex)" or name == "Private Key (WIF)":
                result["valid"] = is_valid_ecdsa_private_key(match)
            elif name == "Ethereum Address":
                result["valid"] = is_valid_secp256k1_pubkey(match)
            elif name == "X.509 Certificate":
                cert_info = parse_x509_certificate(match)
                result.update(cert_info)
                result["valid"] = cert_info.get("valid", False)
            elif name == "Seed Phrase Candidate":
                result["valid"] = True

            ALL_RESULTS.append(result)

# ========================
# ASN.1 DER Decoder (Full Version)
# ========================
class Stream:
    def __init__(self, data: Union[str, bytes]):
        if isinstance(data, str):
            self.hex_data = data
            self.pos = 0
        else:
            self.hex_data = data.hex()
            self.pos = 0

    def get(self) -> int:
        val = int(self.hex_data[self.pos:self.pos+2], 16)
        self.pos += 2
        return val

    def hexDump(self, start, end, raw=False):
        hd = self.hex_data[start:end]
        if raw:
            return hd
        return ' '.join(hd[i:i+2] for i in range(0, len(hd), 2))

    def pos(self):
        return self.pos


class ASN1Tag:
    def __init__(self, stream: Stream):
        self.stream = stream
        self.tagByte = stream.get()
        self.tagClass = self.tagByte & 0xC0
        self.tagConstructed = (self.tagByte & 0x20) != 0
        self.tagNumber = self.tagByte & 0x1F

    def isEOC(self):
        return self.tagClass == 0x00 and self.tagNumber == 0x00

    def typeName(self):
        if self.tagClass == 0x00:
            if self.tagNumber == 0x01:
                return "BOOLEAN"
            elif self.tagNumber == 0x02:
                return "INTEGER"
            elif self.tagNumber == 0x03:
                return "BITSTRING"
            elif self.tagNumber == 0x04:
                return "OCTETSTRING"
            elif self.tagNumber == 0x05:
                return "NULL"
            elif self.tagNumber == 0x06:
                return "OBJECTID"
            elif self.tagNumber == 0x0A:
                return "ENUMERATED"
            elif self.tagNumber == 0x17:
                return "UTCTime"
            elif self.tagNumber == 0x18:
                return "GeneralizedTime"
            elif self.tagNumber == 0x30 and self.tagConstructed:
                return "SEQUENCE"
            elif self.tagNumber == 0x31 and self.tagConstructed:
                return "SET"
        return f"Universal_{self.tagNumber}"


class ASN1:
    def __init__(self, stream: Stream):
        self.stream = stream
        self.header = stream.pos
        self.tag = ASN1Tag(stream)
        self.length = self.decode_length(stream)
        self.sub = None
        if self.tag.tagConstructed and self.length is not None:
            self.sub = []
            end = stream.pos + self.length
            while stream.pos < end:
                self.sub.append(ASN1(stream))
        elif self.tag.tagNumber == 0x02:  # INTEGER
            self.value = self.decode_integer(stream, self.length)
        elif self.tag.tagNumber == 0x03:  # BIT STRING
            unused = stream.get()
            length = self.length - 1
            bits = ''.join(f"{stream.get():08b}" for _ in range(length))
            self.value = bits[:unused]
        elif self.tag.tagNumber == 0x04:  # OCTET STRING
            self.value = stream.hexDump(stream.pos, stream.pos + self.length, raw=True)
        elif self.tag.tagNumber == 0x05:  # NULL
            self.value = None
        elif self.tag.tagNumber == 0x06:  # OBJECT ID
            self.value = self.decode_oid(stream, self.length)
        elif self.tag.tagNumber == 0x17:  # UTCTime
            utc_time = stream.hexDump(stream.pos, stream.pos + self.length, raw=True)
            self.value = bytes.fromhex(utc_time).decode('ascii')
        elif self.tag.tagNumber == 0x18:  # GeneralizedTime
            gtime = stream.hexDump(stream.pos, stream.pos + self.length, raw=True)
            self.value = bytes.fromhex(gtime).decode('ascii')
        elif self.tag.isEOC():
            pass

    @staticmethod
    def decode_length(stream: Stream):
        first = stream.get()
        if first & 0x80:
            num_bytes = first & 0x7F
            if num_bytes > 8:
                raise ValueError("Length too long")
            length = 0
            for _ in range(num_bytes):
                length = (length << 8) + stream.get()
            return length
        else:
            return first

    @staticmethod
    def decode_integer(stream: Stream, length: int):
        val = ''
        for _ in range(length):
            val += f"{stream.get():02x}"
        return val

    @staticmethod
    def decode_oid(stream: Stream, length: int):
        oid = [str(stream.get() // 40) + "." + str(stream.get() % 40)]
        val = 0
        for _ in range(stream.pos, stream.pos + length):
            b = stream.get()
            val = ((val << 7) | (b & 0x7F))
            if not (b & 0x80):
                oid.append(str(val))
                val = 0
        return '.'.join(oid)

    def content(self, max_len=100):
        if self.tag.tagNumber == 0x02:
            return self.value
        elif self.tag.typeName() == "SEQUENCE":
            return [child.content() for child in self.sub]
        return ""

    def toPrettyString(self, indent=""):
        tag_name = self.tag.typeName()
        s = f"{indent}{tag_name} @{self.stream.pos - 2}\n"
        if self.length is not None:
            s += f"{indent}  Length: {self.length}\n"
        if self.tag.tagConstructed and self.sub:
            s += f"{indent}  Sub:\n"
            for child in self.sub:
                s += child.toPrettyString(indent + "    ")
        return s

    def getHexStringValue(self):
        return self.stream.hexDump(self.stream.posStart(), self.stream.posEnd(), raw=True)


