def decrypt_ethereum_keystore(path, passphrase=""):
    try:
        with open(path, 'r') as f:
            key_data = json.load(f)
        private_key = decode_keyfile_json(key_data, passphrase.encode())
        return private_key.hex()
    except Exception as e:
        return None

# ========================
# ECDSA Key Validation
# ========================
def is_valid_secp256k1_pubkey(pubkey_hex):
    if pubkey_hex.startswith("0x"):
        pubkey_hex = pubkey_hex[2:]
    if not re.match(r"^[a-fA-F0-9]{64}$", pubkey_hex):
        return False
    return True

def is_valid_ecdsa_private_key(key_str):
    try:
        if re.match(r"[a-fA-F0-9]{64}", key_str):
            return True
        elif re.match(r"5[HJK][1-9A-Za-z][^OIl]{48,52}|L[A-Za-z0-9]{51}|K[A-Za-z0-9]{51}", key_str):
            return True
        return False
    except:
        return False

