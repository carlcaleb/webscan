def fetch_page(url):
    try:
        headers = {"User-Agent": random.choice(USER_AGENTS)}
        response = requests.get(url, headers=headers, timeout=10)
        if response.status_code == 200:
            return response.text
        print(f"[!] Failed to fetch {url} - Status: {response.status_code}")
    except Exception as e:
        print(f"[!] Error fetching {url}: {e}")
    return ""

def extract_links(html, base_url):
    links = set()
    soup = BeautifulSoup(html, 'html.parser')
    for a_tag in soup.find_all("a", href=True):
        full_url = urljoin(base_url, a_tag["href"])
        parsed = urlparse(full_url)
        if parsed.scheme in ["http", "https"]:
            links.add(full_url)
    return links

def crawl_website(start_url, max_depth=MAX_DEPTH):
    queue = [(start_url, 0)]
    while queue:
        url, depth = queue.pop(0)
        if url in VISITED_URLS or depth > MAX_DEPTH:
            continue
        print(f"[*] Crawling: {url}")
        html = fetch_page(url)
        if html:
            secrets = scan_content_for_secrets(html, url)
            for result in secrets:
                if "-----BEGIN PRIVATE KEY-----" in result["match"]:
                    result["valid"] = is_valid_pem_private_key(result["match"])
                ALL_RESULTS.append(result)
        links = extract_links(html, start_url)
        for link in links:
            if link not in VISITED_URLS:
                queue.append((link, depth + 1))
        VISITED_URLS.add(url)
        time.sleep(random.uniform(0.5, 1.5))

# ========================
# Parse PEM Certificates
# ========================
def is_valid_pem_private_key(pem_data):
    try:
        if pem.detect(pem_data):
            _, _, der_bytes = pem.unarmor(pem_data)
            keys.PrivateKeyInfo.load(der_bytes)
            return True
    except Exception as e:
        return False
    return False

def parse_x509_certificate(cert_data):
    try:
        if pem.detect(cert_data):
            _, _, der_bytes = pem.unarmor(cert_data)
            cert = x509.Certificate.load(der_bytes)
            pub_key = cert["tbs_certificate"]["subject_public_key_info"]
            return {
                "valid": True,
                "issuer": cert["tbs_certificate"]["issuer"].human_friendly,
                "subject": cert["tbs_certificate"]["subject"].human_friendly,
                "pub_key_hex": pub_key.native['public_key'].hex(),
                "not_before": cert["tbs_certificate"]["validity"]["not_before"].native,
                "not_after": cert["tbs_certificate"]["validity"]["not_after"].native
            }
        else:
            return {"valid": False}
    except Exception as e:
        return {"valid": False}

# ========================
# Check Balance on Blockchain
# ========================
def has_balance_on_blockchain(address, chain):
    try:
        if chain == "ethereum":
            url = f"https://api.etherscan.io/api?module=account&action=balance&address= {address}&apikey={ETHERSCAN_API_KEY}"
            resp = requests.get(url)
            data = resp.json()
            return int(data['result']) > 0
        elif chain == "bitcoin":
            url = f"https://blockchair.com/bitcoin/address/ {address}/json"
            resp = requests.get(url)
            data = resp.json()
            return data.get('context', {}).get('balance', 0) > 0
        return True  # Default: assume valid if balance check not supported
    except:
        return False

# ========================
# Export Results to CSV
# ========================
def export_to_desktop_csv(results):
    desktop_path = os.path.join(os.path.expanduser("~"), "Desktop")
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = f"crypto_leaks_{timestamp}.csv"
    filepath = os.path.join(desktop_path, filename)

    fieldnames = ["type", "match", "url", "chain", "valid"]
    try:
        with open(filepath, mode='w', newline='', encoding='utf-8') as file:
            writer = csv.DictWriter(file, fieldnames=fieldnames)
            writer.writeheader()
            for result in results:
                match = result.get("match", "")
                chain = result.get("chain", "N/A")
                is_valid = result.get("valid", False)

                if is_valid and has_balance_on_blockchain(match, chain):
                    writer.writerow({
                        "type": result.get("type", ""),
                        "match": match[:32767],
                        "url": result.get("url", ""),
                        "chain": chain,
                        "valid": is_valid
                    })
        print(f"[+] Results exported to: {filepath}")
    except Exception as e:
        print(f"[!] Error exporting to CSV: {e}")

